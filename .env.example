NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=https://devicefield.com

# Server-only Codex draft ingestion. Never place the token in source control.
CODEX_DRAFT_INGEST_URL=https://devicefield.com/api/internal/codex/drafts
CODEX_DRAFT_INGEST_TOKEN=

# Server-only secret used by /go redirects to record validated affiliate clicks.
# Never prefix this key with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# Newsletter double opt-in and Resend synchronization. Keep all server-only.
NEWSLETTER_TOKEN_SECRET=
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL="Devicefield <contact@devicefield.com>"
SITE_URL=https://devicefield.com

# Optional: useful for direct database/CLI workflows, not used by the Next.js app.
SUPABASE_DB_PASSWORD=

# Optional: use the Supabase pooler connection string if direct db.<ref>.supabase.co
# is IPv6-only on your network. Do not prefix with NEXT_PUBLIC_.
SUPABASE_DB_URL=
